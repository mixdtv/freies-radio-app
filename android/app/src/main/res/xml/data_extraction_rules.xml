<?xml version="1.0" encoding="utf-8"?>
<!--
  Disables both cloud backup (Google Drive auto-backup) and device-to-device
  transfer for the whole app. App stores a persistent device identifier and
  user location; neither should leave the device.

  Android 12+ (API 31) form. android:allowBackup="false" in the manifest
  covers older API levels.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
        <exclude domain="device_root" />
        <exclude domain="device_file" />
        <exclude domain="device_database" />
        <exclude domain="device_sharedpref" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
        <exclude domain="device_root" />
        <exclude domain="device_file" />
        <exclude domain="device_database" />
        <exclude domain="device_sharedpref" />
    </device-transfer>
</data-extraction-rules>
